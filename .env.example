# ── LLM (Groq — free tier) ─────────────────────────────────────────────────
GROQ_API_KEY=

# ── Google Sheets ──────────────────────────────────────────────────────────
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Gmail (outbound email + IMAP reply check) ──────────────────────────────
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=          # Google App Password (not your login password)

# ── LinkedIn ───────────────────────────────────────────────────────────────
LINKEDIN_COOKIES_JSON=

# ── Scraping + Research ────────────────────────────────────────────────────
FIRECRAWL_API_KEY=
SERPAPI_KEY=

# ── VAPI ───────────────────────────────────────────────────────────────────
VAPI_API_KEY=

# ── Booking link (Google Meet or Calendly that creates Meet rooms) ─────────
# Use a Calendly link that auto-creates Google Meet: calendly.com/yourname
# Or a fixed Google Meet room: meet.google.com/xxx-xxxx-xxx
BOOKING_LINK=

# ── WhatsApp via Twilio (optional — only needed for WhatsApp outreach) ─────
# Free sandbox: twilio.com → Messaging → Try it out → WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # sandbox number
